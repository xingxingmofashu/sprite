{
  "name": "sprite",
  "description": "Douyin emoji and sticker downloader browser extension",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
